---
interface Props {
  title: string;
  subtitle?: string;
  season?: string;
  competition?: string;
  lastUpdated?: string;
}

const {
  title = "RC Celta",
  subtitle = "Dashboard · LaLiga",
  season = "2025-2026",
  competition = "LALIGA EA SPORTS",
  lastUpdated = new Date().toLocaleString("es-ES", {
    day: "2-digit",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  }),
} = Astro.props;

import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`Resultados y próximos partidos de LaLiga ${season}. Información del RC Celta de Vigo.`} />
    <title>{title} · Resultados LaLiga</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <div class="dashboard-shell">
      <div class="dashboard-shell__inner">
        <div class="dashboard-panel">
          <header class="dashboard-header">
            <div class="dashboard-header__left">
              <img
                src="/laliga-logo.svg"
                alt="LaLiga"
                width="48"
                height="48"
                class="brand-logo"
              />
              <div class="brand-text">
                <span class="brand-text__sub">{subtitle}</span>
                <span class="brand-text__main">{title}</span>
              </div>
            </div>
            <div class="dashboard-header__meta">
              <div class="meta-pill">
                <span class="meta-pill__dot" aria-hidden="true"></span>
                <span>{season} · {competition}</span>
              </div>
              <time class="meta-updated" datetime={new Date().toISOString()}>
                Actualizado: {lastUpdated}
              </time>
            </div>
          </header>
          <main id="main-content">
            <slot />
          </main>
            <Footer/>
        </div>
      </div>
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/dashboard.css";
  
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .brand-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: 8px;
  }
</style>
