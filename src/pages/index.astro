---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import CeltaHighlight from '../components/CeltaHighlight.astro';
import MatchList from '../components/MatchList.astro';

const API_TOKEN = import.meta.env.FOOTBALL_API_TOKEN;
const API_BASE = 'https://api.football-data.org/v4';
const LALIGA_CODE = 'PD';
const CELTA_ID = 558;

function slugify(name) {
  return name
    .toLowerCase()
    .replace(/[^a-z0-9\s]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
}

function formatMatch(m) {
  const isCelta = m.homeTeam.id === CELTA_ID || m.awayTeam.id === CELTA_ID;
  return {
    id: m.id,
    home: {
      name: m.homeTeam.name,
      shortName: slugify(m.homeTeam.name),
      isCelta: m.homeTeam.id === CELTA_ID
    },
    away: {
      name: m.awayTeam.name,
      shortName: slugify(m.awayTeam.name),
      isCelta: m.awayTeam.id === CELTA_ID
    },
    homeScore: m.score?.fullTime?.home ?? null,
    awayScore: m.score?.fullTime?.away ?? null,
    status: m.status === 'FINISHED' ? 'finished' : m.status === 'IN_PLAY' || m.status === 'LIVE' ? 'live' : 'scheduled',
    date: m.utcDate,
    venue: m.homeTeam.name,
    isHome: m.homeTeam.id === CELTA_ID,
    isCelta
  };
}

let data = null;
let error = null;

try {
  const today = new Date();
  const fromDate = new Date(today);
  fromDate.setDate(fromDate.getDate() - 14);
  const toDate = new Date(today);
  toDate.setDate(toDate.getDate() + 14);

  const from = fromDate.toISOString().split('T')[0];
  const to = toDate.toISOString().split('T')[0];

  const response = await fetch(
    `${API_BASE}/competitions/${LALIGA_CODE}/matches?dateFrom=${from}&dateTo=${to}`,
    { headers: { 'X-Auth-Token': API_TOKEN } }
  );

  if (!response.ok) throw new Error(`API error: ${response.status}`);
  
  const apiData = await response.json();

  const finishedMatches = apiData.matches.filter(m => m.status === 'FINISHED');
  const scheduledMatches = apiData.matches.filter(m => m.status === 'SCHEDULED' || m.status === 'TIMED');

  const celtaMatches = apiData.matches.filter(m => 
    m.homeTeam.id === CELTA_ID || m.awayTeam.id === CELTA_ID
  );
  const celtaFinishedMatches = celtaMatches.filter(m => m.status === 'FINISHED');
  const celtaScheduledMatches = celtaMatches.filter(m => m.status === 'SCHEDULED' || m.status === 'TIMED');
  
  const celtaLastMatch = celtaFinishedMatches.length > 0 ? celtaFinishedMatches[celtaFinishedMatches.length - 1] : null;
  const celtaNextMatch = celtaScheduledMatches.length > 0 ? celtaScheduledMatches[0] : null;

  const jornadas = [...new Set(finishedMatches.map(m => m.matchday))].sort((a, b) => b - a);
  const lastMatchday = jornadas[0] || null;
  const jornadaAnteriorReal = jornadas[1] || null;
  const nextMatchday = scheduledMatches.length > 0 ? scheduledMatches[0].matchday : null;

  const lastMatches = apiData.matches.filter(m => m.matchday === lastMatchday);
  const jornadaAnteriorMatches = jornadaAnteriorReal ? apiData.matches.filter(m => m.matchday === jornadaAnteriorReal) : [];
  const nextMatches = apiData.matches.filter(m => m.matchday === nextMatchday);

  data = {
    jornada: jornadaAnteriorReal || lastMatchday,
    jornadaSiguiente: nextMatchday,
    partidos: jornadaAnteriorMatches.length > 0 ? jornadaAnteriorMatches.map(formatMatch) : lastMatches.map(formatMatch),
    proximosPartidos: nextMatches.map(formatMatch),
    celta: {
      ultimo: celtaLastMatch ? formatMatch(celtaLastMatch) : null,
      proximo: celtaNextMatch ? formatMatch(celtaNextMatch) : null
    },
    fetchedAt: new Date().toISOString()
  };
} catch (e) {
  error = e.message;
}

const jornadaActual = data?.jornada?.toString() || data?.jornadaSiguiente ? (data.jornadaSiguiente - 1).toString() : '28';
const temporada = '2025-2026';

const celtaUltimo = data?.celta?.ultimo;
const celtaProximo = data?.celta?.proximo;

const jornadaAnterior = data?.partidos?.map(p => ({
  id: p.id.toString(),
  home: { name: p.home.name, shortName: p.home.shortName, isCelta: p.home.isCelta },
  away: { name: p.away.name, shortName: p.away.shortName, isCelta: p.away.isCelta },
  homeScore: p.homeScore,
  awayScore: p.awayScore,
  status: p.status,
  date: p.date ? new Date(p.date).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit' }) : '',
  time: p.date ? new Date(p.date).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }) : ''
})) || [];

const proximosPartidos = data?.proximosPartidos?.map(p => ({
  id: p.id.toString(),
  home: { name: p.home.name, shortName: p.home.shortName, isCelta: p.home.isCelta },
  away: { name: p.away.name, shortName: p.away.shortName, isCelta: p.away.isCelta },
  homeScore: p.homeScore,
  awayScore: p.awayScore,
  status: p.status,
  date: p.date ? new Date(p.date).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit' }) : '',
  time: p.date ? new Date(p.date).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }) : ''
})) || [];

const lastUpdated = data?.fetchedAt
  ? new Date(data.fetchedAt).toLocaleString('es-ES', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    })
  : 'Ahora mismo';
---

<DashboardLayout
  title="RC Celta · Última jornada"
  subtitle="Dashboard · LaLiga"
  season={temporada}
  competition="LALIGA EA SPORTS"
  lastUpdated={lastUpdated}
>
  {error && (
    <div class="fetch-error" role="alert">
      Error al cargar datos: {error}
    </div>
  )}

  <div class="dashboard-main">
    <section aria-labelledby="celta-highlight-heading" class="celta-section">
      <h2 id="celta-highlight-heading" class="sr-only">RC Celta de Vigo</h2>

      {celtaUltimo ? (
        <CeltaHighlight
          homeTeam={{ name: celtaUltimo.home.name, shortName: celtaUltimo.home.shortName }}
          awayTeam={{ name: celtaUltimo.away.name, shortName: celtaUltimo.away.shortName }}
          homeScore={celtaUltimo.homeScore}
          awayScore={celtaUltimo.awayScore}
          matchday={jornadaActual}
          date={celtaUltimo.date ? new Date(celtaUltimo.date).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) : ''}
          isHome={celtaUltimo.isHome}
          venue={celtaUltimo.isHome ? 'Estadio de Balaídos' : 'Como visitante'}
        />
      ) : (
        <div class="fetch-error">No hay datos del último partido del Celta</div>
      )}

      {celtaProximo ? (
        <CeltaHighlight
          homeTeam={{ name: celtaProximo.home.name, shortName: celtaProximo.home.shortName }}
          awayTeam={{ name: celtaProximo.away.name, shortName: celtaProximo.away.shortName }}
          homeScore={null}
          awayScore={null}
          matchday={(parseInt(jornadaActual) + 1).toString()}
          date={celtaProximo.date ? new Date(celtaProximo.date).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) : ''}
          time={celtaProximo.date ? new Date(celtaProximo.date).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }) : ''}
          isHome={celtaProximo.isHome}
          venue={celtaProximo.isHome ? 'Estadio de Balaídos' : 'Como visitante'}
        />
      ) : (
        <div class="fetch-error">No hay datos del próximo partido del Celta</div>
      )}
    </section>

    <section aria-label="Partidos de LaLiga" class="matches-section">
      {jornadaAnterior.length > 0 ? (
        <MatchList
          matches={jornadaAnterior}
          title="Última jornada"
          subtitle="Resultados completos"
          jornada={`Jornada ${jornadaActual}`}
        />
      ) : (
        <div class="fetch-error">No hay partidos de la última jornada</div>
      )}

      {proximosPartidos.length > 0 ? (
        <MatchList
          matches={proximosPartidos}
          title="Próxima jornada"
          subtitle="Partidos programados"
          jornada={`Jornada ${parseInt(jornadaActual) + 1}`}
        />
      ) : (
        <div class="fetch-error">No hay partidos programados</div>
      )}
    </section>
  </div>
</DashboardLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .celta-section {
    display: flex;
    flex-direction: column;
    gap: var(--gap-lg);
  }

  .matches-section {
    display: flex;
    flex-direction: column;
    gap: var(--gap-lg);
  }

  .fetch-error {
    margin-top: 0.75rem;
    padding: 0.6rem 0.8rem;
    border-radius: var(--radius-md);
    background: rgba(255, 127, 95, 0.12);
    border: 1px solid rgba(255, 127, 95, 0.6);
    color: var(--color-state-alert);
    font-size: 0.8rem;
  }
</style>
