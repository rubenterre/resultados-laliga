---
interface Team {
  name: string;
  shortName: string;
}

interface Props {
  homeTeam: Team;
  awayTeam: Team;
  homeScore: number | null;
  awayScore: number | null;
  matchday: string;
  date: string;
  time?: string;
  venue: string;
  isHome: boolean;
}

const {
  homeTeam,
  awayTeam,
  homeScore,
  awayScore,
  matchday,
  date,
  time,
  venue,
  isHome
} = Astro.props;

const opponent = isHome ? awayTeam : homeTeam;
const isFinished = homeScore !== null && awayScore !== null;
---

<article class="celta-card celta-card--highlight" aria-label={`RC Celta: ${homeTeam.name} ${homeScore ?? "-"} - ${awayScore ?? "-"} ${awayTeam.name}`}>
  <div class="celta-card__header">
    <div class="celta-card__title">
      <span class="celta-card__kicker">RC Celta de Vigo · Jornada {matchday}</span>
      <h2 class="celta-card__heading">
        {isFinished ? "Último resultado" : "Próximo partido"}
      </h2>
    </div>
    <span class="badge-celta">Celta</span>
  </div>

  <div class="celta-card__scoreline">
    <div class="celta-match">
      <div class="celta-match__team celta-match__team--away">
        <img
          src={`/logos/${homeTeam.shortName.toLowerCase()}.png`}
          alt={homeTeam.name}
          width="48"
          height="48"
          class="celta-match__logo"
        />
        <span class="celta-match__name">{homeTeam.name}</span>
      </div>

      <div class="celta-match__score">
        {isFinished ? (
          <>
            <span class={`celta-match__number ${homeTeam.name.includes("Celta") ? "celta-match__number--celta" : ""}`}>{homeScore}</span>
            <span class="celta-match__divider">-</span>
            <span class={`celta-match__number ${awayTeam.name.includes("Celta") ? "celta-match__number--celta" : ""}`}>{awayScore}</span>
          </>
        ) : (
          <span class="celta-match__vs">vs</span>
        )}
      </div>

      <div class="celta-match__team celta-match__team--home">
        <img
          src={`/logos/${awayTeam.shortName.toLowerCase()}.png`}
          alt={awayTeam.name}
          width="48"
          height="48"
          class="celta-match__logo"
        />
        <span class="celta-match__name">{awayTeam.name}</span>
      </div>
    </div>

    <div class="celta-card__meta">
      <time datetime={date}>{date}</time>
      {time && <span> · {time}</span>}
    </div>
  </div>

  <footer class="celta-card__footer">
    <span class="tag-pill">{venue}</span>
    {isFinished ? (
      <span class="match-status match-status--finished">Finalizado</span>
    ) : (
      <span class="match-status match-status--scheduled">Próximo</span>
    )}
  </footer>
</article>

<style>
  .celta-match {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .celta-match__team {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 140px;
  }

  .celta-match__logo {
    width: 88px;
    height: 88px;
    object-fit: contain;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    padding: 4px;
  }

  .celta-match__team--home {
    order: 3;
  }

  .celta-match__team--away {
    order: 1;
  }

  .celta-match__name {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-soft);
    letter-spacing: 0.08em;
    max-width: 120px;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .celta-match__score {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    order: 2;
  }

  .celta-match__number {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text-main);
  }

  .celta-match__number--celta {
    color: var(--color-celta);
    text-shadow: 0 0 20px rgba(138, 195, 238, 0.7);
  }

  .celta-match__divider {
    font-size: 1.4rem;
    color: var(--color-text-soft);
  }

  .celta-match__vs {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-text-soft);
  }

  .celta-card__meta {
    text-align: center;
  }

  .celta-card__footer {
    justify-content: space-between;
    flex-direction: row-reverse;
  }

  @media (max-width: 405px) {
    .celta-match {
      gap: 0.75rem;
    }

    .celta-match__team {
      width: 90px;
    }

    .celta-match__logo {
      width: 56px;
      height: 56px;
      padding: 2px;
    }

    .celta-match__name {
      font-size: 0.65rem;
      max-width: 80px;
    }

    .celta-match__number {
      font-size: 1.3rem;
    }

    .celta-match__divider,
    .celta-match__vs {
      font-size: 1rem;
    }
  }

  @media (min-width: 600px) {
    .celta-match__number {
      font-size: 3.8rem;
    }
  }
</style>
